# phases/photon_lab_server.py
import os
from flask import Flask, render_template, send_from_directory
from pathlib import Path

app = Flask(__name__)

# Use a sub‑folder for static assets – Flask will serve them automatically
app.static_folder = Path(__file__).parent / "photon_lab"
app.static_url_path = "/photon_lab/"

# Simple index that auto‑loads the React bundle (CRA lives in the same pod)
@app.route("/index.html")
def index():
    # If you used CRA’s “build” folder, point there instead:
    static_path = Path(__file__).parent / "photon_lab" / "dist-client" / "index.html"
    if static_path.is_file():
        return render_template("index.html", bundle="dist-client")
    # fallback to index.html in the repo root
    page = Path(__file__).parent / "photon_lab" / "index.html"
    if page.is_file():
        return render_template("index.html")
    return flask.abort(404)

# Directly serve any static files (e.g., images, CSS) if you need them
@app.route("/<filepath:.+>", guard_u404=False)
def static_file(filepath):
    return send_from_directory(app.static_folder, filepath, mimetype='application/octet-stream')

if __name__ == "__main__":
    # When deploy to Heroku/Render you will expose PORT=5000 env var.
    FLAG = os.getenv("PORT", 5000)
    app.run(host="0.0.0.0", port=int(FLAG), debug=False)
```

